{
  "manifest_version": 3,
  "name": "Virtual Try-On",
  "version": "1.0.0",
  "description": "Virtual try-on app for fashion items on Myntra and Amazon",
  "permissions": [
    "scripting",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.myntra.com/*",
    "https://www.amazon.in/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
},
  "action": {
    "default_popup": "popup.html",
    "default_title": "Virtual Try-On"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.myntra.com/*",
        "https://www.amazon.in/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
  
}
